APP_NAME="UPS IMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Default connection (also used by some Laravel internals)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Multi-company MySQL connections (session "active_db" switches between these names)
UPS_DB_HOST=127.0.0.1
UPS_DB_PORT=3306
UPS_DB_DATABASE=ups
UPS_DB_USERNAME=root
UPS_DB_PASSWORD=

URS_DB_HOST=127.0.0.1
URS_DB_PORT=3306
URS_DB_DATABASE=urs
URS_DB_USERNAME=root
URS_DB_PASSWORD=

UCS_DB_HOST=127.0.0.1
UCS_DB_PORT=3306
UCS_DB_DATABASE=ucs
UCS_DB_USERNAME=root
UCS_DB_PASSWORD=

# Department 2 (optional — define if you use ups2 / urs2 / ucs2 in config/database.php)
UPS2_DB_HOST=127.0.0.1
UPS2_DB_PORT=3306
UPS2_DB_DATABASE=ups2
UPS2_DB_USERNAME=root
UPS2_DB_PASSWORD=

URS2_DB_HOST=127.0.0.1
URS2_DB_PORT=3306
URS2_DB_DATABASE=urs2
URS2_DB_USERNAME=root
URS2_DB_PASSWORD=

UCS2_DB_HOST=127.0.0.1
UCS2_DB_PORT=3306
UCS2_DB_DATABASE=ucs2
UCS2_DB_USERNAME=root
UCS2_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=

# database | sync | redis — production often uses database or redis + a worker
QUEUE_CONNECTION=database
# If QUEUE_CONNECTION=database, optionally set which DB connection stores jobs:
# DB_QUEUE_CONNECTION=mysql

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

MYSQL_ATTR_SSL_CA=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SCOUT_DRIVER=database
