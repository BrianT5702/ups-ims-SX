APP_NAME="UPS IMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Docker Desktop: app in container, MySQL on Windows → APP_URL=http://localhost:8080 (or your mapped port)
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Default connection (sessions when SESSION_DRIVER=database, etc.)
# Docker Desktop + MySQL on host (Laragon): DB_HOST=host.docker.internal
# PHP running on the same machine as MySQL (no Docker): DB_HOST=127.0.0.1
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

# Multi-company MySQL connections (session "active_db" switches between these names)
UPS_DB_HOST=127.0.0.1
UPS_DB_PORT=3306
UPS_DB_DATABASE=ups
UPS_DB_USERNAME=root
UPS_DB_PASSWORD=

URS_DB_HOST=127.0.0.1
URS_DB_PORT=3306
URS_DB_DATABASE=urs
URS_DB_USERNAME=root
URS_DB_PASSWORD=

UCS_DB_HOST=127.0.0.1
UCS_DB_PORT=3306
UCS_DB_DATABASE=ucs
UCS_DB_USERNAME=root
UCS_DB_PASSWORD=

# Department 2 (optional — define if you use ups2 / urs2 / ucs2 in config/database.php)
UPS2_DB_HOST=127.0.0.1
UPS2_DB_PORT=3306
UPS2_DB_DATABASE=ups2
UPS2_DB_USERNAME=root
UPS2_DB_PASSWORD=

URS2_DB_HOST=127.0.0.1
URS2_DB_PORT=3306
URS2_DB_DATABASE=urs2
URS2_DB_USERNAME=root
URS2_DB_PASSWORD=

UCS2_DB_HOST=127.0.0.1
UCS2_DB_PORT=3306
UCS2_DB_DATABASE=ucs2
UCS2_DB_USERNAME=root
UCS2_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=

# database | sync | redis — production often uses database or redis + a worker
QUEUE_CONNECTION=database
# If QUEUE_CONNECTION=database, optionally set which DB connection stores jobs:
# DB_QUEUE_CONNECTION=mysql

REDIS_CLIENT=phpredis
# Same rule as DB: use host.docker.internal from inside Docker if Redis runs on Windows
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

BROADCAST_CONNECTION=log

FILESYSTEM_DISK=local

MYSQL_ATTR_SSL_CA=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

SCOUT_DRIVER=database

# -----------------------------------------------------------------------------
# Docker Desktop + MySQL on Windows (Laragon)
# -----------------------------------------------------------------------------
# In .env set: DB_HOST=host.docker.internal (and UPS_/URS_/UCS_*_DB_HOST the same).
# APP_URL=http://localhost:8080 when mapping -p 8080:80
#
# Rebuild after changing docker/* or Dockerfile:  docker build -t ups-ims:latest .
# Mount .env so PHP always sees DB settings (recommended):
#   docker rm -f ups-ims-test
#   docker run -d --name ups-ims-test -p 8080:80 -v "${PWD}/.env:/var/www/html/.env:ro" ups-ims:latest
# PowerShell: use ${PWD}\.env on Windows path if needed, e.g.
#   docker run -d --name ups-ims-test -p 8080:80 -v "${PWD}\.env:/var/www/html/.env:ro" ups-ims:latest
# Start Laragon MySQL before browsing http://localhost:8080

# -----------------------------------------------------------------------------
# docker compose (MySQL in Docker, service hostname: mysql)
# -----------------------------------------------------------------------------
# MYSQL_ROOT_PASSWORD=secret
# DB_HOST=mysql
# UPS_DB_HOST=mysql  URS_DB_HOST=mysql  UCS_DB_HOST=mysql
# UPS2_DB_HOST=mysql  URS2_DB_HOST=mysql  UCS2_DB_HOST=mysql
# DB_USERNAME=root  DB_PASSWORD=secret  (match MYSQL_ROOT_PASSWORD)
# Same user/password for UPS_/URS_/UCS_* if you use root for all.
# APP_PUBLISH_PORT=8080
# APP_URL=http://localhost:8080   (must match APP_PUBLISH_PORT, e.g. :8090 if you change the port)
# Run: docker compose up -d --build
# PhpMyAdmin: docker compose --profile tools up -d  → http://localhost:8081
# Fresh DB volume runs docker/mysql/init-databases.sql once (ups, urs, ucs, ups2, urs2, ucs2).
